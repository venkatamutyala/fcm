# FCM kernel overrides — batteries-included for VM workloads
#
# Filesystem support (cloud-init CIDATA + all common formats)
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y
CONFIG_NLS_UTF8=y
CONFIG_BTRFS_FS=y
CONFIG_XFS_FS=y
#
# Container support (Docker, Podman, etc.)
CONFIG_OVERLAY_FS=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_USER_NS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_VS=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_CHAIN_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
#
# VPN/Tailscale support
CONFIG_TUN=y
#
# NFS client (shared storage)
CONFIG_NFS_FS=y
CONFIG_NFS_V4=y
#
# Misc useful modules
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_FUSE_FS=y
CONFIG_KEYS=y
CONFIG_ENCRYPTED_KEYS=y
